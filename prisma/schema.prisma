generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  mainImage      String?
  body           String
  seoTitle       String?
  seoDescription String?
  published      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Project {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  category       String
  mainImage      String?
  gallery        String   @default("[]")
  description    String
  seoTitle       String?
  seoDescription String?
  published      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PortfolioItem {
  id            String   @id @default(cuid())
  slug          String   @unique
  titleEn       String
  titleAr       String
  descriptionEn String
  descriptionAr String
  category      String
  imageUrl      String
  tags           String   @default("[]")
  featured       Boolean  @default(false)
  imageAltEn     String   @default("")
  imageCaptionEn String   @default("")
  imageAltAr     String   @default("")
  imageCaptionAr String   @default("")
  order          Int      @default(0)
  status         String   @default("published") // "draft" | "published" | "archived"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  products       PortfolioProduct[]
}

model PortfolioProduct {
  id              String        @id @default(cuid())
  portfolioItemId String
  portfolioItem   PortfolioItem @relation(fields: [portfolioItemId], references: [id], onDelete: Cascade)
  nameEn          String
  nameAr          String
  descriptionEn   String        @default("")
  descriptionAr   String        @default("")
  icon            String        @default("")
  imageUrl        String        @default("")
  specs           String        @default("{}") // JSON: { "key": "value" }
  displayOrder    Int           @default(0)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([portfolioItemId, active])
}

model Service {
  id            String   @id @default(cuid())
  slug          String   @unique
  titleEn       String
  titleAr       String
  descriptionEn String
  descriptionAr String
  icon          String
  order         Int      @default(0)
  active        Boolean   @default(true)
  status        String    @default("published") // "draft" | "published" | "archived"
  updatedAt     DateTime? @updatedAt
}

model ImpactStat {
  id      String @id @default(cuid())
  labelEn String
  labelAr String
  value   String
  suffix  String @default("")
  order   Int    @default(0)
}

model Insight {
  id           String    @id @default(cuid())
  slug         String    @unique
  titleEn      String
  titleAr      String
  summaryEn    String
  summaryAr    String
  bodyEn       String
  bodyAr       String
  coverImage   String    @default("")
  category     String    @default("General")
  published    Boolean   @default(false)
  publishedAt  DateTime?
  status       String    @default("draft") // "draft" | "published" | "archived"
  canonicalUrl String    @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([published, publishedAt])
}

model SeoConfig {
  id              String  @id @default(cuid())
  pageKey         String
  locale          String
  metaTitle       String
  metaDescription String
  ogTitle         String
  ogDescription   String
  ogImageUrl      String  @default("")
  canonical       String?

  @@unique([pageKey, locale])
}

model SiteSettings {
  id        String @id @default("global")

  // ── Marketing & Analytics ──────────────────────────────
  ga4Id              String @default("")
  gtmId              String @default("")
  metaPixelId        String @default("")
  clarityId          String @default("")
  hotjarId           String @default("")
  snapchatPixelId    String @default("")
  tiktokPixelId      String @default("")
  yandexMetricaId    String @default("")

  // ── Verification ───────────────────────────────────────
  gscVerificationCode String @default("")
  googleMyBusinessUrl String @default("")

  // ── Site-wide Assets ───────────────────────────────────
  logoUrl            String @default("")
  footerLogoUrl      String @default("")
  footerText         String @default("")
  faviconUrl         String @default("")
  ogImageUrl         String @default("")
  heroVideoUrl       String @default("")
  splashImageUrl     String @default("")

  // ── Integrations ───────────────────────────────────────
  webhookUrl         String @default("")

  // ── Social Media ───────────────────────────────────────
  socialLinkedIn     String @default("")
  socialTwitter      String @default("")
  socialFacebook     String @default("")
  socialInstagram    String @default("")
  socialWhatsApp     String @default("")
  socialYoutube      String @default("")

  updatedAt DateTime @updatedAt
}

model VaultDocument {
  id            String   @id @default(cuid())
  titleEn       String
  titleAr       String
  descriptionEn String   @default("")
  descriptionAr String   @default("")
  categoryEn    String   @default("")
  categoryAr    String   @default("")
  icon          String   @default("")
  status        String   @default("Active") // "Verified" | "Active" | "Expired"
  validUntil    String   @default("")
  documentUrl   String   @default("")
  displayOrder  Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active, displayOrder])
}

model BrandLogo {
  id           String   @id @default(cuid())
  name         String
  logoUrl      String   @default("")
  websiteUrl   String   @default("")
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, displayOrder])
}

model TeamMember {
  id          String   @id @default(cuid())
  nameEn      String
  nameAr      String
  roleEn      String
  roleAr      String
  bioEn       String   @default("")
  bioAr       String   @default("")
  photoUrl    String   @default("")
  linkedinUrl String   @default("")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id           String   @id @default(cuid())
  clientNameEn String
  clientNameAr String
  companyEn    String   @default("")
  companyAr    String   @default("")
  quoteEn      String
  quoteAr      String
  rating       Int      @default(5)
  photoUrl     String   @default("")
  published    Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published])
}

model FormSubmission {
  id         String   @id @default(cuid())
  type       String   @default("quote")
  name       String   @default("")
  email      String
  message    String   @default("")
  category   String   @default("")
  data       String   @default("{}")
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}
